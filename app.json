{
  "expo": {
    "name": "ZenPulse",
    "slug": "zenpulse-production-app",
    "version": "1.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "plugins": [
      [
        "expo-localization",
        {
          "supportedLocales": {
            "ios": ["en", "ru", "de"],
            "android": ["en", "ru", "de"]
          }
        }
      ]
    ]
  }
}
